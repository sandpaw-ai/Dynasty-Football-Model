# Virtual environment
.venv/
venv/
env/

# Python caches
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
build/
dist/

# Local database (regenerated daily by GitHub Actions)
*.db
*.db-journal

# Generated site (built by GitHub Actions, served from there)
dynasty_site/

# Local environment file (don't commit secrets)
.env

# Manual data drops (per-source CSV mirrors).
# We DO commit the computed-RAS CSV (generated by scripts/build_ras_csv.py
# from public nflverse data). Custom local exports stay ignored.
data/ras/*.xlsx
data/ras/*.tsv
data/ras/*_local.csv
data/cfbd/*.csv
data/cfbd/*.xlsx
data/cfbd/*.tsv

# v0.14.0: similarity comps cache is a build artifact — regenerated each
# launcher run when the similarity_career_arc source syncs. Don't commit
# (would just churn on every build).
data/similarity_comps_cache.json

# v0.15.0: per-format VORP / scarcity diagnostics — also regenerated by
# the similarity source each run.
data/similarity_vorp_debug.json

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
