# Virtual environment
.venv/
venv/
env/

# Python caches
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
build/
dist/

# Local database (regenerated daily by GitHub Actions)
*.db
*.db-journal

# Generated site (built by GitHub Actions, served from there)
dynasty_site/

# Local environment file (don't commit secrets)
.env

# Manual data drops (per-source CSV mirrors).
# We DO commit the computed-RAS CSV (generated by scripts/build_ras_csv.py
# from public nflverse data). Custom local exports stay ignored.
data/ras/*.xlsx
data/ras/*.tsv
data/ras/*_local.csv
data/cfbd/*.csv
data/cfbd/*.xlsx
data/cfbd/*.tsv

# v0.14.0: similarity comps cache is a build artifact — regenerated each
# launcher run when the similarity_career_arc source syncs. Don't commit
# (would just churn on every build).
data/similarity_comps_cache.json

# v0.15.0: per-format VORP / scarcity diagnostics — also regenerated by
# the similarity source each run.
data/similarity_vorp_debug.json

# v1.0+ engine output (regenerated by launcher / `run_engine(persist=True)`).
data/engine_v1/

# v2.0+ fantasy-arc corpus + sidecar (regenerated by launcher).
data/engine_v2/

# v1.2.0 cohort diagnostics (regenerated on every engine run).
# Retained as a gitignore even though v2.0 removed the cohort diagnostic
# file — prevents accidental re-introduction if v1.2 caches are ever
# left behind on a dev machine.
data/diagnostics/

# v2.4 PFR scraper HTML cache (~60 MB). Source of truth is the
# normalised CSV at data/nflverse/player_stats_season_pre1999.csv.gz;
# the cache is regenerable by re-running scripts/build_pre1999_corpus.py.
data/pfr_cache/

# v3.0 sports-reference HTML cache. Cache only; the parsed/normalized
# data lives at data/sos/*.csv(.gz) and is regenerable by re-running
# scripts/build_cfb_sos_corpus.py. Shared with v3.0 PR 1 by convention.
data/sr_cache/

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Consensus snapshots: dated history is regenerated daily, keep only the
# latest pointer + the crosswalk in git so the site builds offline.
data/consensus/ktc_[0-9]*-[0-9]*-[0-9]*.json
